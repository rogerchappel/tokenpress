{
  "name": "tokenpress",
  "version": "0.1.0",
  "description": "Local-first terminal transcript compactor for agent logs that preserves commands, errors, paths, and decisions.",
  "type": "module",
  "bin": {
    "tokenpress": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-logs",
    "cli",
    "context",
    "local-first",
    "terminal",
    "transcript"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/tokenpress.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/tokenpress/issues"
  },
  "homepage": "https://github.com/rogerchappel/tokenpress#readme",
  "sideEffects": false,
  "packageManager": "npm@11.6.2"
}
